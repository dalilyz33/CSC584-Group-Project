-- Run this script only after these tables exist:
-- STUDENT
-- ADMIN
-- NOTIFICATIONCATEGORY

CREATE TABLE ASSISTANCEAPPLICATION (
    APPLICATION_ID INTEGER NOT NULL
        GENERATED ALWAYS AS IDENTITY
        (START WITH 1, INCREMENT BY 1),

    STUDENT_ID INTEGER NOT NULL,
    APPLICATION_REVIEWEDBY INTEGER,
    APPLICATION_TYPE VARCHAR(30) NOT NULL,
    APPLICATION_DATE DATE NOT NULL,
    APPLICATION_STATUS VARCHAR(20) DEFAULT 'Pending',
    APPLICATION_SUPPORTINGDOCUMENT VARCHAR(255),

    PRIMARY KEY (APPLICATION_ID),

    CONSTRAINT FK_APPLICATION_STUDENT
        FOREIGN KEY (STUDENT_ID)
        REFERENCES STUDENT(STUDENT_ID),

    CONSTRAINT FK_APPLICATION_ADMIN
        FOREIGN KEY (APPLICATION_REVIEWEDBY)
        REFERENCES ADMIN(STAFF_ID)
);

CREATE TABLE VOUCHER (
    VOUCHER_ID INTEGER NOT NULL
        GENERATED ALWAYS AS IDENTITY
        (START WITH 1, INCREMENT BY 1),

    STUDENT_ID INTEGER NOT NULL,
    CATEGORY_ID INTEGER NOT NULL,
    VOUCHER_ASSIGNEDBY INTEGER NOT NULL,
    VOUCHER_QUANTITY INTEGER NOT NULL,
    VOUCHER_VALUE DECIMAL(10,2) NOT NULL,
    VOUCHER_STATUS VARCHAR(20) DEFAULT 'Active',
    VOUCHER_ASSIGNEDDATE DATE NOT NULL,
    VOUCHER_EXPIRYDATE DATE NOT NULL,

    PRIMARY KEY (VOUCHER_ID),

    CONSTRAINT FK_VOUCHER_STUDENT
        FOREIGN KEY (STUDENT_ID)
        REFERENCES STUDENT(STUDENT_ID),

    CONSTRAINT FK_VOUCHER_CATEGORY
        FOREIGN KEY (CATEGORY_ID)
        REFERENCES NOTIFICATIONCATEGORY(CATEGORY_ID),

    CONSTRAINT FK_VOUCHER_ADMIN
        FOREIGN KEY (VOUCHER_ASSIGNEDBY)
        REFERENCES ADMIN(STAFF_ID)
);

CREATE TABLE VOUCHERREDEMPTION (
    REDEMPTION_ID INTEGER NOT NULL
        GENERATED ALWAYS AS IDENTITY
        (START WITH 1, INCREMENT BY 1),

    STUDENT_ID INTEGER NOT NULL,
    VOUCHER_ID INTEGER NOT NULL,
    REDEMPTION_DATE DATE NOT NULL,

    PRIMARY KEY (REDEMPTION_ID),

    CONSTRAINT FK_REDEMPTION_STUDENT
        FOREIGN KEY (STUDENT_ID)
        REFERENCES STUDENT(STUDENT_ID),

    CONSTRAINT FK_REDEMPTION_VOUCHER
        FOREIGN KEY (VOUCHER_ID)
        REFERENCES VOUCHER(VOUCHER_ID)
);

